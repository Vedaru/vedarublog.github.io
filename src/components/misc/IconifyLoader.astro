---
// 全局Iconify加载器组件
// 在页面头部加载，确保图标库尽早可用

export interface Props {
	preloadIcons?: string[]; // 需要预加载的图标列表
	timeout?: number; // 加载超时时间
	retryCount?: number; // 重试次数
}

const { preloadIcons = [], timeout = 10000, retryCount = 3 } = Astro.props;
---

<script type="application/json" id="iconify-loader-config" set:html={JSON.stringify({ preloadIcons, timeout, retryCount })} />
<script>
	import { initIconifyLoader } from "../../scripts/widgets/iconify-loader";
	const el = document.getElementById("iconify-loader-config");
	if (el) initIconifyLoader(JSON.parse(el.textContent || "{}"));
</script>

<!-- 为不支持JavaScript的情况提供备用方案 -->
<noscript>
  <style>
    iconify-icon {
      display: none;
    }
    .icon-fallback {
      display: inline-block;
    }
  </style>
</noscript>
