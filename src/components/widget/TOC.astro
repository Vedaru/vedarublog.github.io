---
import type { MarkdownHeading } from "astro";

// import { siteConfig } from "../../config";

// import { url } from "../../utils/url-utils";

interface Props {
	class?: string;
	headings: MarkdownHeading[];
}

let { headings = [] } = Astro.props;

let minDepth = 10;
for (const heading of headings) {
	minDepth = Math.min(minDepth, heading.depth);
}

const className = Astro.props.class;
// const isPostsRoute =
// 	Astro.url.pathname.includes("/posts/") || headings.length > 0;

// const removeTailingHash = (text: string) => {
// 	let lastIndexOfHash = text.lastIndexOf("#");
// 	if (lastIndexOfHash !== text.length - 1) {
// 		return text;
// 	}
//
// 	return text.substring(0, lastIndexOfHash);
// };

// let heading1Count = 1;

// const maxLevel = siteConfig.toc.depth;
---
<table-of-contents class:list={[className, "group"]} id="toc">
    <!-- TOC内容将由JavaScript动态生成 -->
</table-of-contents>

<script>
import {
	buildSidebarTocMarkup,
	cacheSectionOffsets,
	collectHeadingsFromDocument,
	createTransitionDeferredUpdater,
	findActiveSectionIndex,
	findVisibleSectionIndices,
	isPostPagePath,
	scheduleTocDomInit,
	scheduleTocIdleWork,
	scrollToTocHeading,
	shouldSkipTocLayoutWork,
} from "../../utils/toc-utils";

class TableOfContents extends HTMLElement {
    tocEl: HTMLElement | null = null;
    visibleClass = "visible";
    anchorNavTarget: HTMLElement | null = null;
    headingIdxMap = new Map<string, number>();
    headings: HTMLElement[] = [];
    sections: HTMLElement[] = [];
    tocEntries: HTMLAnchorElement[] = [];
    active: boolean[] = [];
    activeIndicator: HTMLElement | null = null;
    sectionOffsets: Array<{ top: number; bottom: number } | null> = [];
    tocEntryMetrics: Array<{ top: number; height: number }> = [];
    tocHeightCached = 0;
    prevIndicatorMin = -1;
    prevIndicatorMax = -1;
    resizeTimer = 0;
    transitionUpdater = createTransitionDeferredUpdater(() =>
        this.refreshActiveState(true),
    );
    heavyLayoutReady = false;
    heavyLayoutScheduled = false;
    scrollRaf = 0;

    resolveTocSection = (heading: HTMLElement): HTMLElement => {
        const path = window.location.pathname;
        if (path.includes("/diary")) {
            return heading;
        }

        const parent = heading.parentElement;
        if (!parent) return heading;
        // 父元素有多个直接子元素说明是整体内容容器（非纯节容器），
        // 用标题本身作 section anchor。
        // 避免 getBoundingClientRect 在 innerHTML 写入后立即触发强制重排。
        if (parent.childElementCount > 1) {
            return heading;
        }
        return parent;
    };

    handleScroll = () => {
        if (!this.heavyLayoutReady || shouldSkipTocLayoutWork()) return;
        if (this.scrollRaf) return;
        this.scrollRaf = requestAnimationFrame(() => {
            this.scrollRaf = 0;
            this.refreshActiveState(false);
        });
    };

    cacheSectionOffsets = () => {
        this.sectionOffsets = cacheSectionOffsets(this.sections);
    };

    cacheTocEntryMetrics = () => {
        if (!this.tocEl) return;
        this.tocHeightCached = this.tocEl.clientHeight;
        this.tocEntryMetrics = this.tocEntries.map((entry) => ({
            top: entry.offsetTop,
            height: entry.offsetHeight,
        }));
    };

    handleResize = () => {
        if (this.resizeTimer) window.clearTimeout(this.resizeTimer);
        this.resizeTimer = window.setTimeout(() => {
            this.resizeTimer = 0;
            this.cacheSectionOffsets();
            this.cacheTocEntryMetrics();
            this.prevIndicatorMin = -1;
            this.prevIndicatorMax = -1;
            this.refreshActiveState(true);
        }, 150);
    };

    computeActiveFromScroll = (): boolean[] => {
        const nextActive = new Array(this.tocEntries.length).fill(false);
        if (!this.sections.length) return nextActive;

        if (!this.sectionOffsets.length) {
            this.cacheSectionOffsets();
        }

        const scrollTop = window.scrollY;
        const viewportBottom = scrollTop + window.innerHeight;
        const visibleIndices = findVisibleSectionIndices(
            this.sectionOffsets,
            scrollTop,
            viewportBottom,
        );

        if (visibleIndices.length > 0) {
            for (const idx of visibleIndices) {
                nextActive[idx] = true;
            }
        } else {
            const activeIdx = findActiveSectionIndex(
                this.sectionOffsets,
                scrollTop,
                viewportBottom,
            );
            if (activeIdx !== null) {
                nextActive[activeIdx] = true;
            }
        }

        return nextActive;
    };

    hasActiveChanged = (nextActive: boolean[]): boolean => {
        for (let i = 0; i < nextActive.length; i++) {
            if (nextActive[i] !== this.active[i]) return true;
        }
        return false;
    };

    syncVisibleClasses = (nextActive: boolean[]) => {
        for (let i = 0; i < nextActive.length; i++) {
            const entry = this.tocEntries[i];
            if (!entry) continue;
            if (nextActive[i]) {
                entry.classList.add(this.visibleClass);
            } else {
                entry.classList.remove(this.visibleClass);
            }
        }
    };

    applyTocUiUpdate = (nextActive: boolean[]) => {
        if (shouldSkipTocLayoutWork()) {
            this.transitionUpdater.schedule();
            return;
        }

        if (!this.heavyLayoutReady) {
            this.scheduleHeavyLayout();
            return;
        }

        let min = nextActive.length;
        let max = -1;

        for (let i = 0; i < nextActive.length; i++) {
            if (nextActive[i]) {
                min = Math.min(min, i);
                max = Math.max(max, i);
            }
        }

        const indicatorChanged =
            min !== this.prevIndicatorMin || max !== this.prevIndicatorMax;

        if (indicatorChanged) {
            this.syncVisibleClasses(nextActive);
        }

        if (min <= max && this.tocEl && this.tocEntryMetrics.length) {
            const minMetric = this.tocEntryMetrics[min];
            const maxMetric = this.tocEntryMetrics[max];
            if (minMetric && maxMetric) {
                const minTop = minMetric.top;
                const maxTop = maxMetric.top;
                const maxBottom = maxTop + maxMetric.height;
                const tocHeight = this.tocHeightCached;

                if (indicatorChanged) {
                    this.activeIndicator?.setAttribute(
                        "style",
                        `top: ${minTop}px; height: ${maxBottom - minTop}px; opacity: 1`,
                    );
                    this.prevIndicatorMin = min;
                    this.prevIndicatorMax = max;
                }

                if (!this.anchorNavTarget) {
                    const targetScrollTop =
                        maxBottom - minTop < 0.9 * tocHeight
                            ? minTop - 32
                            : maxTop - tocHeight * 0.8;

                    const currentScroll = this.tocEl.scrollTop;
                    if (Math.abs(currentScroll - targetScrollTop) > 4) {
                        this.tocEl.scrollTop = targetScrollTop;
                    }
                }
                return;
            }
        }

        if (indicatorChanged) {
            this.activeIndicator?.setAttribute("style", "opacity: 0");
            this.prevIndicatorMin = -1;
            this.prevIndicatorMax = -1;
        }
    };

    refreshActiveState = (forceUpdate: boolean) => {
        if (shouldSkipTocLayoutWork()) {
            this.transitionUpdater.schedule();
            return;
        }

        if (!this.heavyLayoutReady) {
            this.scheduleHeavyLayout();
            return;
        }

        const nextActive = this.computeActiveFromScroll();
        const changed = forceUpdate || this.hasActiveChanged(nextActive);
        if (!changed) return;

        this.active = nextActive;

        if (
            this.anchorNavTarget &&
            this.anchorNavTarget.id &&
            this.headingIdxMap.has(this.anchorNavTarget.id)
        ) {
            const anchorIdx = this.headingIdxMap.get(this.anchorNavTarget.id)!;
            const anchorOffset = this.sectionOffsets[anchorIdx];
            if (anchorOffset && anchorOffset.top <= window.scrollY + 120) {
                this.anchorNavTarget = null;
            }
        }

        this.applyTocUiUpdate(nextActive);
    };

    markActiveHeading = (idx: number) => {
        const nextActive = new Array(this.tocEntries.length).fill(false);
        nextActive[idx] = true;
        this.active = nextActive;
        this.prevIndicatorMin = -1;
        this.prevIndicatorMax = -1;
        this.applyTocUiUpdate(nextActive);
    };

    handleAnchorClick = (event: Event) => {
        const anchor = event
            .composedPath()
            .find((element) => element instanceof HTMLAnchorElement);

        if (anchor) {
            event.preventDefault();
            window.tocClickTimestamp = Date.now();

            const id = decodeURIComponent(anchor.hash?.substring(1));
            scrollToTocHeading(id);

            const idx = this.headingIdxMap.get(id);
            if (idx !== undefined) {
                this.anchorNavTarget = this.headings[idx];
            } else {
                this.anchorNavTarget = null;
            }
        }
    };

    scheduleHeavyLayout = () => {
        if (this.heavyLayoutReady || this.heavyLayoutScheduled) return;
        this.heavyLayoutScheduled = true;

        const runHeavy = () => {
            this.heavyLayoutScheduled = false;
            if (shouldSkipTocLayoutWork()) {
                document.addEventListener(
                    "swup:transition-ready",
                    () => this.scheduleHeavyLayout(),
                    { once: true },
                );
                return;
            }
            this.cacheSectionOffsets();
            this.cacheTocEntryMetrics();
            this.heavyLayoutReady = true;
            this.refreshActiveState(true);
        };

        scheduleTocIdleWork(runHeavy);
    };

    connectedCallback() {
        // Swup 换页由 Layout 编排器 Phase 2 统一 init，避免双通道初始化
        if ((window as any).swup) {
            return;
        }

        scheduleTocDomInit(() => this.init());
    };

    teardown() {
        this.tocEl?.removeEventListener("click", this.handleAnchorClick, {
            capture: true,
        });

        this.sections = [];
        this.headings = [];
        this.tocEntries = [];
        this.active = [];
        this.headingIdxMap.clear();
        this.anchorNavTarget = null;
        this.tocEl = null;
        this.activeIndicator = null;
        this.sectionOffsets = [];
        this.tocEntryMetrics = [];
        this.tocHeightCached = 0;
        this.prevIndicatorMin = -1;
        this.prevIndicatorMax = -1;

        if (this.resizeTimer) {
            window.clearTimeout(this.resizeTimer);
            this.resizeTimer = 0;
        }
        if (this.scrollRaf) {
            cancelAnimationFrame(this.scrollRaf);
            this.scrollRaf = 0;
        }
        window.removeEventListener("resize", this.handleResize);
        window.removeEventListener("scroll", this.handleScroll);

        this.transitionUpdater.cleanup();
        this.heavyLayoutReady = false;
        this.heavyLayoutScheduled = false;
    }

    init() {
        this.teardown();
        this.dataset.managedByLayout = "true";
        this.heavyLayoutReady = false;
        this.heavyLayoutScheduled = false;

        // 重新生成TOC内容
        this.regenerateTOC();

        this.tocEl = this;

        this.tocEl.addEventListener("click", this.handleAnchorClick, {
            capture: true,
        });

        this.activeIndicator = document.getElementById("active-indicator");

        this.tocEntries = Array.from(
            this.querySelectorAll<HTMLAnchorElement>("a[href^='#']")
        );

        if (this.tocEntries.length === 0) return;

        this.sections = new Array(this.tocEntries.length);
        this.headings = new Array(this.tocEntries.length);
        for (let i = 0; i < this.tocEntries.length; i++) {
            const id = decodeURIComponent(this.tocEntries[i].hash?.substring(1));
            const heading = document.getElementById(id);
            const section = heading
                ? this.resolveTocSection(heading)
                : null;
            if (heading instanceof HTMLElement && section instanceof HTMLElement) {
                this.headings[i] = heading;
                this.sections[i] = section;
                this.headingIdxMap.set(id, i);
            }
        }
        this.active = new Array(this.tocEntries.length).fill(false);

        window.addEventListener("resize", this.handleResize, { passive: true });
        window.addEventListener("scroll", this.handleScroll, { passive: true });

        this.scheduleHeavyLayout();
    };

    regenerateTOC(retryCount = 0) {
        if (!isPostPagePath()) {
            this.innerHTML = "";
            delete this.dataset.loaded;
            return;
        }

        const headings = collectHeadingsFromDocument();
        if (headings.length === 0 && retryCount < 3) {
            setTimeout(() => this.regenerateTOC(retryCount + 1), 120);
            return;
        }
        if (headings.length === 0) {
            this.innerHTML = "";
            delete this.dataset.loaded;
            return;
        }

        this.innerHTML = buildSidebarTocMarkup(headings);
        this.dataset.loaded = "true";
    }

    disconnectedCallback() {
        this.teardown();
    };
}

if (!customElements.get("table-of-contents")) {
    customElements.define("table-of-contents", TableOfContents);
}
</script>

<style>
  table-of-contents#toc {
      /* 限制为视口高度的一部分，超出时在 TOC 内部滚动 */
      max-height: calc(100vh - 200px);
      overflow: auto;
      -webkit-overflow-scrolling: touch; /* 平滑滚动（移动端） */
      overscroll-behavior: contain; /* 防止滚动穿透 */
      position: relative;
      scroll-behavior: auto;
      display: block;
  }

  table-of-contents#toc #active-indicator {
      transition: opacity 0.15s ease;
  }

  /* 隐藏滚动条（仍允许滚动） */
  table-of-contents#toc::-webkit-scrollbar {
      display: none;
  }
</style>