---
import ConfigCarrier from "@components/ConfigCarrier.astro";
import FullscreenWallpaper from "@components/misc/FullscreenWallpaper.astro";
import MusicPlayer from "@components/widget/MusicPlayer.svelte";
import Pio from "@components/widget/Pio.svelte"; // 使用 Svelte 版本的 Pio 组件
import {
	fullscreenWallpaperConfig,
	musicPlayerConfig,
	pioConfig,
	profileConfig,
	siteConfig,
	commentConfig,
} from "@/config";
import { umamiConfig } from "../config";

import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	BANNER_HEIGHT_HOME,
	DARK_MODE,
	DEFAULT_THEME,
	defaultFavicons,
	LIGHT_MODE,
	PAGE_WIDTH,
} from "@constants";
import type { Favicon } from "../types/config";
import { getDefaultBannerUrl } from "../utils/banner-utils";
import { isHomePagePath } from "../utils/route-utils";
import { url } from "../utils/url-utils";
import "../styles/main.css";
import "../styles/wallpaper-navbar-transparent.css";
import "../styles/expressive-code.css";
import "../styles/panel-animations.css";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
}

let { title, banner, description, lang, setOGTypeArticle, postSlug } =
	Astro.props;

// apply a class to the body element to decide the height of the banner, only used for initial page load
// Swup can update the body for each page visit, but it's after the page transition, causing a delay for banner height change
// so use Swup hooks instead to change the height immediately when a link is clicked
const isHomePage = isHomePagePath(Astro.url.pathname);

// defines global css variables
// why doing this in Layout instead of GlobalStyles: https://github.com/withastro/astro/issues/6728#issuecomment-1502203757
const configHue = siteConfig.themeColor.hue;

// 获取导航栏透明模式配置
const navbarTransparentMode =
	siteConfig.banner?.navbar?.transparentMode || "semi";

// 判断是否应该显示顶部高光效果（只在full和semifull模式下显示）
const shouldShowTopHighlight =
	navbarTransparentMode === "full" || navbarTransparentMode === "semifull";

// 获取默认banner图片
const getDefaultBanner = (): string => getDefaultBannerUrl();

if (!banner || typeof banner !== "string" || banner.trim() === "") {
	banner = getDefaultBanner();
}

// TODO don't use post cover as banner for now
banner = getDefaultBanner();

const enableBanner = !!siteConfig.banner.src;

let pageTitle: string;
if (title) {
	pageTitle = `${title} - ${siteConfig.title}`;
} else {
	pageTitle = siteConfig.subtitle
		? `${siteConfig.title} - ${siteConfig.subtitle}`
		: siteConfig.title;
}

let ogImageUrl: string | undefined;
if (siteConfig.generateOgImages && postSlug) {
	ogImageUrl = new URL(`/og/${postSlug}.png`, Astro.site).toString();
}

const favicons: Favicon[] =
	siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;

// const siteLang = siteConfig.lang.replace('_', '-')
if (!lang) {
	lang = `${siteConfig.lang}`;
}
const siteLang = lang.replace("_", "-");

const bannerOffsetByPosition = {
	top: `${BANNER_HEIGHT_EXTEND}vh`,
	center: `${BANNER_HEIGHT_EXTEND / 2}vh`,
	bottom: "0",
};
const bannerOffset =
	bannerOffsetByPosition[siteConfig.banner.position || "center"];

const umamiEnabled = umamiConfig.enabled || false;
const umamiScripts = umamiConfig.scripts || ""; // 获取Umami scripts配置

// 构建字体配置的 CSS 变量
// ASCII 字体优先级最高（用于英文、数字等），CJK 字体作为回退
let bodyFontFamily = "";
if (siteConfig.font) {
	const fonts: string[] = [];
	// 先添加 ASCII 字体（优先级最高）
	if (siteConfig.font.asciiFont?.fontFamily) {
		const asciiFont = siteConfig.font.asciiFont.fontFamily;
		// 如果字体名包含空格，需要用引号包围
		fonts.push(asciiFont.includes(" ") ? `"${asciiFont}"` : asciiFont);
	}
	// 再添加 CJK webfont（预加载，减少 swap CLS）
	fonts.push('"Microsoft YaHei Web"');
	// 再添加 CJK 字体（作为回退）
	if (siteConfig.font.cjkFont?.fontFamily) {
		const cjkFont = siteConfig.font.cjkFont.fontFamily;
		// 如果字体名包含空格，需要用引号包围
		fonts.push(cjkFont.includes(" ") ? `"${cjkFont}"` : cjkFont);
	}
	// 添加系统字体作为最终回退（不含未加载的 Roboto，避免与正文栈不一致）
	fonts.push(
		"system-ui",
		"-apple-system",
		"BlinkMacSystemFont",
		"'Segoe UI'",
		"Oxygen",
		"Ubuntu",
		"Cantarell",
		"'Open Sans'",
		"'Helvetica Neue'",
		"sans-serif",
	);
	// 组合成完整的 font-family 字符串
	bodyFontFamily = fonts.join(", ");
}
---

<!doctype html>
<html
	lang={siteLang}
	class="bg-[var(--page-bg)] text-[14px] md:text-[16px]"
	data-overlayscrollbars-initialize
	data-wallpaper-mode={siteConfig.wallpaperMode.defaultMode}
	data-post-list-layout={siteConfig.postListLayout?.defaultMode || "list"}
>
	<head>
		<!-- 第三方分析脚本 - 延迟加载优化 -->
		<script is:inline>
			// 使用 requestIdleCallback 延迟加载第三方脚本
			function loadAnalytics() {
				// Google Tag Manager
				(function (w, d, s, l, i) {
					w[l] = w[l] || [];
					w[l].push({
						"gtm.start": new Date().getTime(),
						event: "gtm.js",
					});
					var f = d.getElementsByTagName(s)[0],
						j = d.createElement(s),
						dl = l != "dataLayer" ? "&l=" + l : "";
					j.async = true;
					j.src =
						"https://www.googletagmanager.com/gtm.js?id=" + i + dl;
					f.parentNode.insertBefore(j, f);
				})(window, document, "script", "dataLayer", "GTM-KRX3XGVH");
			}

			// 在浏览器空闲时加载，或者在 3 秒后加载
			if ("requestIdleCallback" in window) {
				requestIdleCallback(loadAnalytics, { timeout: 3000 });
			} else {
				setTimeout(loadAnalytics, 3000);
			}
		</script>

		<title>{pageTitle}</title>
		<meta charset="UTF-8" />
		<meta
			name="site-build-id"
			content={import.meta.env.PUBLIC_SITE_BUILD_ID}
		/>
		<meta name="description" content={description || pageTitle} />
		{
			siteConfig.keywords && siteConfig.keywords.length > 0 && (
				<meta
					name="keywords"
					content={siteConfig.keywords.join(", ")}
				/>
			)
		}
		<meta name="author" content={profileConfig.name} />
		<meta property="og:site_name" content={siteConfig.title} />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description || pageTitle} />
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		{
			setOGTypeArticle ? (
				<meta property="og:type" content="article" />
			) : (
				<meta property="og:type" content="website" />
			)
		}
		<meta name="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description || pageTitle} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		{
			favicons.map((favicon) => (
				<link
					rel="icon"
					href={
						favicon.src.startsWith("/")
							? url(favicon.src)
							: favicon.src
					}
					sizes={favicon.sizes}
					media={
						favicon.theme &&
						`(prefers-color-scheme: ${favicon.theme})`
					}
				/>
			))
		}

		<!-- Set the theme before the page is rendered to avoid a flash -->
		<script
			is:inline
			define:vars={{
				DEFAULT_THEME,
				LIGHT_MODE,
				DARK_MODE,
				BANNER_HEIGHT,
				BANNER_HEIGHT_EXTEND,
				PAGE_WIDTH,
				configHue,
				defaultWallpaperMode: siteConfig.wallpaperMode.defaultMode,
				defaultPostListLayout:
					siteConfig.postListLayout?.defaultMode || "list",
				allowPostListSwitch:
					siteConfig.postListLayout?.allowSwitch ?? false,
				pageScaling: siteConfig.pageScaling,
			}}
		>
			// Load the theme from local storage
			const theme = localStorage.getItem("theme") || DEFAULT_THEME;
			let isDark = false;
			switch (theme) {
				case LIGHT_MODE:
					document.documentElement.classList.remove("dark");
					isDark = false;
					break;
				case DARK_MODE:
					document.documentElement.classList.add("dark");
					isDark = true;
					break;
			}

			// Set the theme for Expressive Code based on current mode
			const expressiveTheme = isDark ? "github-dark" : "github-light";
			const currentTheme =
				document.documentElement.getAttribute("data-theme");
			// 只在主题不同时才更新，避免触发不必要的重绘
			if (currentTheme !== expressiveTheme) {
				document.documentElement.setAttribute(
					"data-theme",
					expressiveTheme,
				);
			}

			// Load the hue from local storage
			const hue = localStorage.getItem("hue") || configHue;
			document.documentElement.style.setProperty("--hue", hue);

			// 使用 CSS dvh 替代 JS 计算，避免移动端 URL 栏变化导致的 CLS
			// dvh 会动态适应视口高度变化，不再需要 JS 计算和 resize 监听
			document.documentElement.style.setProperty(
				"--banner-height-extend",
				`${BANNER_HEIGHT_EXTEND}dvh`,
			);
			document.documentElement.style.setProperty(
				"--banner-height-home",
				`${BANNER_HEIGHT + BANNER_HEIGHT_EXTEND}vh`,
			);
			document.documentElement.style.setProperty(
				"--banner-height",
				`${BANNER_HEIGHT}vh`,
			);

			// 壁纸模式 — 首屏前写入 html data 属性，CSS 驱动布局（避免 CLS）
			var wallpaperMode =
				localStorage.getItem("wallpaperMode") || defaultWallpaperMode;
			if (
				wallpaperMode !== "banner" &&
				wallpaperMode !== "fullscreen" &&
				wallpaperMode !== "none"
			) {
				wallpaperMode = defaultWallpaperMode;
			}
			document.documentElement.setAttribute(
				"data-wallpaper-mode",
				wallpaperMode,
			);

			// 文章列表布局 — allowSwitch 关闭时忽略 localStorage 陈旧值
			var postListLayout = defaultPostListLayout;
			if (allowPostListSwitch) {
				postListLayout =
					localStorage.getItem("postListLayout") ||
					defaultPostListLayout;
			}
			if (postListLayout !== "grid" && postListLayout !== "list") {
				postListLayout = defaultPostListLayout;
			}
			document.documentElement.setAttribute(
				"data-post-list-layout",
				postListLayout,
			);

			// pageScaling — 同步 inline 设置（优先级高于 md:text-[16px]），避免 CLS
			(function () {
				if (!pageScaling || !pageScaling.enable) return;

				function adjustPageScale() {
					var html = document.documentElement;
					if (
						html.classList.contains("is-changing") ||
						html.classList.contains("is-animating")
					) {
						return;
					}

					var isTouch =
						(window.matchMedia &&
							(window.matchMedia("(pointer:coarse)").matches ||
								window.matchMedia("(hover: none)").matches)) ||
						"ontouchstart" in window;
					var isPortrait =
						window.matchMedia &&
						window.matchMedia("(orientation: portrait)").matches;
					var isTabletLike = isTouch || window.innerWidth <= 1280;
					if (isTabletLike || isPortrait) {
						document.documentElement.style.fontSize = "";
						return;
					}
					var targetWidth = pageScaling.targetWidth || 2000;
					var currentWidth = document.documentElement.clientWidth;
					var scale = currentWidth / targetWidth;
					if (scale > 1) scale = 1;
					if (scale < 0.85) scale = 0.85;
					document.documentElement.style.fontSize = scale * 100 + "%";
				}

				requestAnimationFrame(() => {
					requestAnimationFrame(adjustPageScale);
				});
				window.addEventListener("resize", adjustPageScale);
				window.addEventListener("orientationchange", adjustPageScale);
				function scheduleAdjustPageScale() {
					var schedule =
						window.requestIdleCallback ||
						function (cb) {
							requestAnimationFrame(function () {
								requestAnimationFrame(cb);
							});
						};
					schedule(adjustPageScale);
				}

				function registerAdjustPageScaleOnIdle() {
					if (typeof window.__onSwupPageIdlePhase === "function") {
						window.__onSwupPageIdlePhase(scheduleAdjustPageScale);
						return true;
					}
					return false;
				}

				if (!registerAdjustPageScaleOnIdle()) {
					document.addEventListener("DOMContentLoaded", function () {
						registerAdjustPageScaleOnIdle();
					});
				}
			})();
		</script>
		<!-- Critical layout shell styles: see layout-stable.css (loaded via main.css) -->
		<style
			define:vars={{
				configHue,
				"page-width": `${PAGE_WIDTH}rem`,
				"font-sans": bodyFontFamily,
			}}
			is:global
		>
			html,
			body {
				font-family: var(
					--font-sans,
					"ZenMaruGothic-Medium",
					"Microsoft YaHei",
					system-ui,
					sans-serif
				);
			}
		</style>

		<!-- defines global css variables. This will be applied to <html> <body> and some other elements idk why -->
		<link
			rel="preload"
			href="/assets/font/ZenMaruGothic-Medium.woff2"
			as="font"
			type="font/woff2"
			crossorigin="anonymous"
		/>
		<link
			rel="preload"
			href="/assets/font/微软雅黑.woff2"
			as="font"
			type="font/woff2"
			crossorigin="anonymous"
		/>

		<slot name="head" />

		<!-- Pio 看板娘样式 - 异步加载，避免阻塞首屏渲染 -->
		{pioConfig.enable && (
			<>
				<link
					rel="preload"
					href="/pio/static/pio.css"
					as="style"
				/>
				<link
					rel="stylesheet"
					href="/pio/static/pio.css"
					media="print"
					onload="this.media='all'"
				/>
				<noscript>
					<link rel="stylesheet" href="/pio/static/pio.css" />
				</noscript>
			</>
		)}

		<link
			rel="alternate"
			type="application/rss+xml"
			title={profileConfig.name}
			href={`${Astro.site}rss.xml`}
		/>

		<script is:inline src="/js/core/scroll-utils.js" data-cfasync="false"></script>
		<script is:inline src="/js/core/route-utils.js" data-cfasync="false"></script>
		<script is:inline src="/js/core/navbar-scroll-sync.js" data-cfasync="false"></script>
		<script is:inline src="/js/core/swup-bootstrap.js" data-cfasync="false"></script>
		<script is:inline src="/js/core/visit-layout.js" data-cfasync="false"></script>
		<script
			is:inline
			defer
			src="/js/banner-drift.js"
			data-cfasync="false"
		></script>
		<script
			is:inline
			defer
			src="/js/swup-transition-performance.js"
			data-cfasync="false"
		></script>
		<script
			is:inline
			defer
			src="/js/smooth-scroll.js"
			data-cfasync="false"
		></script>
		<script
			is:inline
			defer
			src="/js/home-pre-scroll.js"
			data-cfasync="false"
		></script>

		<!-- Umami Analytics - 延迟加载 -->
		{umamiEnabled && umamiScripts && (
			<template id="umami-scripts-tpl" set:html={umamiScripts} />
			<script is:inline>
				if ('requestIdleCallback' in window) {
					requestIdleCallback(function() {
						var tpl = document.getElementById('umami-scripts-tpl');
						if (tpl) {
							document.head.appendChild(tpl.content);
							tpl.remove();
						}
					}, { timeout: 3000 });
				} else {
					setTimeout(function() {
						var tpl = document.getElementById('umami-scripts-tpl');
						if (tpl) {
							document.head.appendChild(tpl.content);
							tpl.remove();
						}
					}, 3000);
				}
			</script>
		)}

	</head>
	<body
		class="min-h-screen"
		class:list={[{ "lg:is-home": isHomePage, "is-home": isHomePage }]}
		data-overlayscrollbars-initialize
	>
		<!-- Shell 关键样式：preload 提前发现，link 仍置于 body 首行以保证覆盖顺序 -->
		<link rel="preload" href="/assets/css/shell-critical.css" as="style" />
		<link rel="stylesheet" href="/assets/css/shell-critical.css" />
		<script is:inline>
			window.__bootstrapWallpaperBodyClasses?.();
		</script>
		<noscript
			><iframe
				src="https://www.googletagmanager.com/ns.html?id=GTM-KRX3XGVH"
				height="0"
				width="0"
				style="display:none;visibility:hidden"></iframe></noscript
		>
		<!-- 页面顶部渐变高光效果 - 只在full和semifull模式下显示 -->
		{shouldShowTopHighlight && <div class="top-gradient-highlight" />}

		<ConfigCarrier />
		<FullscreenWallpaper config={fullscreenWallpaperConfig} />
		<slot />

		<!-- Music Player - 仅在启用时加载 -->
		{musicPlayerConfig.enable && <MusicPlayer client:idle />}

		<!-- Pio 看板娘组件 - 仅在启用时加载 -->
		{pioConfig.enable && <Pio client:idle />}

		<!-- Swup 换页滚动锁占位（不参与文档流，避免 300vh 撑高引发 CLS） -->
		<div id="page-height-extend" aria-hidden="true"></div>
	</body>
</html>

<style
	is:global
	define:vars={{
		bannerOffset,
		"banner-height-home": `${BANNER_HEIGHT_HOME}vh`,
		"banner-height": `${BANNER_HEIGHT}vh`,
	}}
>
	@tailwind components;
	@layer components {
		@media (min-width: 1280px) {
			.enable-banner.is-home #banner-wrapper {
				@apply h-[var(--banner-height-home)] translate-y-[var(--banner-height-extend)];
			}
			.enable-banner #banner-wrapper {
				@apply h-[var(--banner-height-home)];
			}
			.enable-banner.is-home #banner {
				@apply h-[var(--banner-height-home)] translate-y-0;
			}
			.enable-banner #banner {
				@apply h-[var(--banner-height-home)] translate-y-[var(--bannerOffset)];
			}
			.enable-banner.is-home #main-grid {
				@apply translate-y-[var(--banner-height-extend)];
			}
			.enable-banner #top-row {
				@apply h-[calc(var(--banner-height-home)_-_4.5rem)] transition-all duration-300;
			}
			.enable-banner.is-home #sidebar-sticky {
				@apply top-[calc(1rem_-_var(--banner-height-extend))];
			}
		}
		.navbar-hidden {
			@apply opacity-0 -translate-y-16;
		}

		/* Water waves animation */
		.waves > .parallax use {
			animation: wave 25s cubic-bezier(0.5, 0.5, 0.45, 0.5) infinite;
		}
		@keyframes wave {
			0% {
				transform: translate3d(-90px, 0, 0);
			}
			100% {
				transform: translate3d(85px, 0, 0);
			}
		}
	}
</style>

<script>
	import { initThemeBootstrap } from "../scripts/theme-bootstrap";
	import { initSwupLifecycle } from "../scripts/swup-lifecycle";
	import { initNavbarScroll } from "../scripts/navbar-scroll";

	initThemeBootstrap();
	initSwupLifecycle();
	initNavbarScroll();
</script>

<!-- 代码块折叠功能 -->
<script>
	import "../scripts/code-collapse.js";
</script>

<!-- 番剧页：Swup 切换后重新初始化卡片与懒加载 -->
<script>
	import "../scripts/anime-page.js";
</script>

<!-- Mermaid 图表：Swup 换页后重新渲染 -->
<script>
	import "../scripts/mermaid-init.js";
</script>

{siteConfig.showLastModified && (
	<script is:inline src="/js/last-modified.js" data-cfasync="false"></script>
)}

{commentConfig.enable && (
	<script is:inline>
		(function () {
			function loadCommentScript(src) {
				if (document.querySelector('script[src="' + src + '"]')) return;
				var s = document.createElement("script");
				s.src = src;
				s.defer = true;
				s.setAttribute("data-cfasync", "false");
				document.body.appendChild(s);
			}
			function bootCommentScripts() {
				if (!document.getElementById("tcomment")) return;
				loadCommentScript("/js/scroll-protection.js");
				loadCommentScript("/js/twikoo-init.js");
			}
			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", bootCommentScripts);
			} else {
				bootCommentScripts();
			}
			document.addEventListener("swup:content:replace", bootCommentScripts);
		})();
	</script>
)}

<!-- 主题切换综合性能优化器（包含代码块优化、重型元素优化、性能诊断） -->
<script>
	import "../scripts/theme-optimizer.js";
</script>
