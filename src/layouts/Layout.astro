---
import ConfigCarrier from "@components/ConfigCarrier.astro";
import FullscreenWallpaper from "@components/misc/FullscreenWallpaper.astro";
import MusicPlayer from "@components/widget/MusicPlayer.svelte";
import Pio from "@components/widget/Pio.svelte"; // 使用 Svelte 版本的 Pio 组件
import {
	fullscreenWallpaperConfig,
	musicPlayerConfig,
	pioConfig,
	profileConfig,
	siteConfig,
	commentConfig,
} from "@/config";
import { umamiConfig } from "../config";

import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	BANNER_HEIGHT_HOME,
	DARK_MODE,
	DEFAULT_THEME,
	defaultFavicons,
	LIGHT_MODE,
	PAGE_WIDTH,
} from "@constants";
import type { Favicon } from "../types/config";
import { getDefaultBannerUrl } from "../utils/banner-utils";
import { isMainHomePage } from "../utils/route-utils";
import { url } from "../utils/url-utils";
import { readFileSync } from "node:fs";
import { join } from "node:path";
import { mapPlaylistEntry, type Song } from "@/lib/audio/useAudioPlayer";
import playlistJson from "../../public/assets/music/playlist.json";
import "../styles/main.css";
import "../styles/wallpaper-navbar-transparent.css";
import "../styles/panel-animations.css";

const shellCriticalCss = readFileSync(
	join(process.cwd(), "public/assets/css/shell-critical.css"),
	"utf8",
);

let musicInitialSong: Song | undefined;
if (
	musicPlayerConfig.enable &&
	Array.isArray(playlistJson) &&
	playlistJson.length > 0
) {
	musicInitialSong = mapPlaylistEntry(
		playlistJson[0] as Record<string, unknown>,
		0,
	);
}

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
}

let { title, banner, description, lang, setOGTypeArticle, postSlug } =
	Astro.props;

// apply a class to the body element to decide the height of the banner, only used for initial page load
// Swup can update the body for each page visit, but it's after the page transition, causing a delay for banner height change
// so use Swup hooks instead to change the height immediately when a link is clicked
const isHomePage = isMainHomePage(Astro.url.pathname);

// defines global css variables
// why doing this in Layout instead of GlobalStyles: https://github.com/withastro/astro/issues/6728#issuecomment-1502203757
const configHue = siteConfig.themeColor.hue;

// 获取导航栏透明模式配置
const navbarTransparentMode =
	siteConfig.banner?.navbar?.transparentMode || "semi";

// 判断是否应该显示顶部高光效果（只在full和semifull模式下显示）
const shouldShowTopHighlight =
	navbarTransparentMode === "full" || navbarTransparentMode === "semifull";

// 获取默认banner图片
const getDefaultBanner = (): string => getDefaultBannerUrl();

if (!banner || typeof banner !== "string" || banner.trim() === "") {
	banner = getDefaultBanner();
}

// TODO don't use post cover as banner for now
banner = getDefaultBanner();

let pageTitle: string;
if (title) {
	pageTitle = `${title} - ${siteConfig.title}`;
} else {
	pageTitle = siteConfig.subtitle
		? `${siteConfig.title} - ${siteConfig.subtitle}`
		: siteConfig.title;
}

let ogImageUrl: string | undefined;
if (siteConfig.generateOgImages && postSlug) {
	ogImageUrl = new URL(`/og/${postSlug}.png`, Astro.site).toString();
}

const favicons: Favicon[] =
	siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;

// const siteLang = siteConfig.lang.replace('_', '-')
if (!lang) {
	lang = `${siteConfig.lang}`;
}
const siteLang = lang.replace("_", "-");

const bannerOffsetByPosition = {
	top: `${BANNER_HEIGHT_EXTEND}vh`,
	center: `${BANNER_HEIGHT_EXTEND / 2}vh`,
	bottom: "0",
};
const bannerOffset =
	bannerOffsetByPosition[siteConfig.banner.position || "center"];

const umamiEnabled = umamiConfig.enabled || false;
const umamiScripts = umamiConfig.scripts || ""; // 获取Umami scripts配置

// 构建字体配置的 CSS 变量
// ASCII 字体优先级最高（用于英文、数字等），CJK 字体作为回退
let bodyFontFamily = "";
if (siteConfig.font) {
	const fonts: string[] = [];
	// 先添加 ASCII 字体（优先级最高）
	if (siteConfig.font.asciiFont?.fontFamily) {
		const asciiFont = siteConfig.font.asciiFont.fontFamily;
		// 如果字体名包含空格，需要用引号包围
		fonts.push(asciiFont.includes(" ") ? `"${asciiFont}"` : asciiFont);
	}
	// 再添加 CJK webfont（预加载，减少 swap CLS）
	fonts.push('"Microsoft YaHei Web"');
	// 再添加 CJK 字体（作为回退）
	if (siteConfig.font.cjkFont?.fontFamily) {
		const cjkFont = siteConfig.font.cjkFont.fontFamily;
		// 如果字体名包含空格，需要用引号包围
		fonts.push(cjkFont.includes(" ") ? `"${cjkFont}"` : cjkFont);
	}
	// 添加系统字体作为最终回退（不含未加载的 Roboto，避免与正文栈不一致）
	fonts.push(
		"system-ui",
		"-apple-system",
		"BlinkMacSystemFont",
		"'Segoe UI'",
		"Oxygen",
		"Ubuntu",
		"Cantarell",
		"'Open Sans'",
		"'Helvetica Neue'",
		"sans-serif",
	);
	// 组合成完整的 font-family 字符串
	bodyFontFamily = fonts.join(", ");
}
---

<!doctype html>
<html
	lang={siteLang}
	class="bg-[var(--page-bg)] text-[14px] md:text-[16px]"
	data-overlayscrollbars-initialize
	data-wallpaper-mode={siteConfig.wallpaperMode.defaultMode}
	data-post-list-layout={siteConfig.postListLayout?.defaultMode || "list"}
>
	<head>
		<title>{pageTitle}</title>
		<meta charset="UTF-8" />
		<meta
			name="site-build-id"
			content={import.meta.env.PUBLIC_SITE_BUILD_ID}
		/>
		<meta name="description" content={description || pageTitle} />
		{
			siteConfig.keywords && siteConfig.keywords.length > 0 && (
				<meta
					name="keywords"
					content={siteConfig.keywords.join(", ")}
				/>
			)
		}
		<meta name="author" content={profileConfig.name} />
		<meta property="og:site_name" content={siteConfig.title} />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description || pageTitle} />
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		{
			setOGTypeArticle ? (
				<meta property="og:type" content="article" />
			) : (
				<meta property="og:type" content="website" />
			)
		}
		<meta name="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description || pageTitle} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		{
			favicons.map((favicon) => (
				<link
					rel="icon"
					href={
						favicon.src.startsWith("/")
							? url(favicon.src)
							: favicon.src
					}
					sizes={favicon.sizes}
					media={
						favicon.theme &&
						`(prefers-color-scheme: ${favicon.theme})`
					}
				/>
			))
		}

		<!-- Set the theme before the page is rendered to avoid a flash -->
		<script
			is:inline
			define:vars={{
				DEFAULT_THEME,
				LIGHT_MODE,
				DARK_MODE,
				BANNER_HEIGHT,
				BANNER_HEIGHT_EXTEND,
				bannerOffset,
				PAGE_WIDTH,
				configHue,
				bodyFontFamily,
				defaultWallpaperMode: siteConfig.wallpaperMode.defaultMode,
				defaultPostListLayout:
					siteConfig.postListLayout?.defaultMode || "list",
				allowPostListSwitch:
					siteConfig.postListLayout?.allowSwitch ?? false,
				pageScaling: siteConfig.pageScaling,
			}}
		>
			// Load the theme from local storage
			const theme = localStorage.getItem("theme") || DEFAULT_THEME;
			let isDark = false;
			switch (theme) {
				case LIGHT_MODE:
					document.documentElement.classList.remove("dark");
					isDark = false;
					break;
				case DARK_MODE:
					document.documentElement.classList.add("dark");
					isDark = true;
					break;
			}

			// Set the theme for Expressive Code based on current mode
			const expressiveTheme = isDark ? "github-dark" : "github-light";
			const currentTheme =
				document.documentElement.getAttribute("data-theme");
			// 只在主题不同时才更新，避免触发不必要的重绘
			if (currentTheme !== expressiveTheme) {
				document.documentElement.setAttribute(
					"data-theme",
					expressiveTheme,
				);
			}

			// Load the hue from local storage
			const hue = localStorage.getItem("hue") || configHue;
			document.documentElement.style.setProperty("--hue", hue);
			document.documentElement.style.setProperty("--font-sans", bodyFontFamily);
			document.documentElement.style.setProperty(
				"--page-width",
				`${PAGE_WIDTH}rem`,
			);

			// 使用 CSS dvh 替代 JS 计算，避免移动端 URL 栏变化导致的 CLS
			// dvh 会动态适应视口高度变化，不再需要 JS 计算和 resize 监听
			document.documentElement.style.setProperty(
				"--banner-height-extend",
				`${BANNER_HEIGHT_EXTEND}dvh`,
			);
			document.documentElement.style.setProperty(
				"--banner-height-home",
				`${BANNER_HEIGHT + BANNER_HEIGHT_EXTEND}vh`,
			);
			document.documentElement.style.setProperty(
				"--banner-height",
				`${BANNER_HEIGHT}vh`,
			);
			document.documentElement.style.setProperty(
				"--bannerOffset",
				bannerOffset,
			);

			// 壁纸模式 — 首屏前写入 html data 属性，CSS 驱动布局（避免 CLS）
			var wallpaperMode =
				localStorage.getItem("wallpaperMode") || defaultWallpaperMode;
			if (
				wallpaperMode !== "banner" &&
				wallpaperMode !== "fullscreen" &&
				wallpaperMode !== "none"
			) {
				wallpaperMode = defaultWallpaperMode;
			}
			document.documentElement.setAttribute(
				"data-wallpaper-mode",
				wallpaperMode,
			);

			// 文章列表布局 — allowSwitch 关闭时忽略 localStorage 陈旧值
			var postListLayout = defaultPostListLayout;
			if (allowPostListSwitch) {
				postListLayout =
					localStorage.getItem("postListLayout") ||
					defaultPostListLayout;
			}
			if (postListLayout !== "grid" && postListLayout !== "list") {
				postListLayout = defaultPostListLayout;
			}
			document.documentElement.setAttribute(
				"data-post-list-layout",
				postListLayout,
			);

			// pageScaling — 同步 inline 设置（优先级高于 md:text-[16px]），避免 CLS
			(function () {
				if (!pageScaling || !pageScaling.enable) return;

				function isMobileOrTabletLike() {
					var isTouch =
						(window.matchMedia &&
							(window.matchMedia("(pointer:coarse)").matches ||
								window.matchMedia("(hover: none)").matches)) ||
						"ontouchstart" in window;
					var isPortrait =
						window.matchMedia &&
						window.matchMedia("(orientation: portrait)").matches;
					return isTouch || window.innerWidth <= 1280 || isPortrait;
				}

				function adjustPageScale() {
					if (isMobileOrTabletLike()) {
						document.documentElement.style.fontSize = "";
						return;
					}

					var html = document.documentElement;
					if (
						html.classList.contains("is-changing") ||
						html.classList.contains("is-animating")
					) {
						return;
					}

					var targetWidth = pageScaling.targetWidth || 2000;
					var currentWidth = document.documentElement.clientWidth;
					var scale = currentWidth / targetWidth;
					if (scale > 1) scale = 1;
					if (scale < 0.85) scale = 0.85;
					document.documentElement.style.fontSize = scale * 100 + "%";
				}

				// 首 paint 前同步设置 rem 基准，避免 load+idle 延迟触发全局 layout shift
				adjustPageScale();
				window.__adjustPageScale = adjustPageScale;
				window.__themePageScaling = pageScaling;
			})();
		</script>
		<!-- Critical layout shell styles: see layout-stable.css (loaded via main.css) -->
		<!-- defines global css variables. This will be applied to <html> <body> and some other elements idk why -->
		<link
			rel="preload"
			href="/assets/font/ZenMaruGothic-Medium.woff2"
			as="font"
			type="font/woff2"
			crossorigin="anonymous"
		/>
		<link
			rel="preload"
			href="/assets/font/微软雅黑.woff2"
			as="font"
			type="font/woff2"
			crossorigin="anonymous"
		/>

		<slot name="head" />

		<!-- Pio 看板娘样式 - 异步加载，避免阻塞首屏渲染 -->
		{pioConfig.enable && (
			<>
				<link
					rel="preload"
					href="/pio/static/pio.css"
					as="style"
				/>
				<link
					rel="stylesheet"
					href="/pio/static/pio.css"
					media="print"
					onload="this.media='all'"
				/>
				<noscript>
					<link rel="stylesheet" href="/pio/static/pio.css" />
				</noscript>
			</>
		)}

		<link
			rel="alternate"
			type="application/rss+xml"
			title={profileConfig.name}
			href={`${Astro.site}rss.xml`}
		/>

		<style is:global set:html={shellCriticalCss} />

		{umamiEnabled && umamiScripts && (
			<template id="umami-scripts-tpl" set:html={umamiScripts} />
		)}

		<script>
			import "../scripts/layout-critical";
		</script>
		<script>
			import "../scripts/layout-deferred";
		</script>

	</head>
	<body
		class="min-h-screen"
		class:list={[{ "lg:is-home": isHomePage, "is-home": isHomePage }]}
		data-overlayscrollbars-initialize
	>
		<script is:inline>
			(function () {
				var mode =
					document.documentElement.getAttribute(
						"data-wallpaper-mode",
					) || "banner";
				var body = document.body;
				body.classList.remove(
					"enable-banner",
					"wallpaper-transparent",
					"no-banner-mode",
				);
				switch (mode) {
					case "banner":
						body.classList.add("enable-banner");
						break;
					case "fullscreen":
						body.classList.add(
							"wallpaper-transparent",
							"no-banner-mode",
						);
						break;
					case "none":
						body.classList.add("no-banner-mode");
						break;
				}
				requestAnimationFrame(function () {
					requestAnimationFrame(function () {
						document.documentElement.classList.add("layout-ready");
					});
				});
			})();
		</script>
		<noscript
			><iframe
				src="https://www.googletagmanager.com/ns.html?id=GTM-KRX3XGVH"
				height="0"
				width="0"
				style="display:none;visibility:hidden"></iframe></noscript
		>
		<!-- 页面顶部渐变高光效果 - 只在full和semifull模式下显示 -->
		{shouldShowTopHighlight && <div class="top-gradient-highlight" />}

		<ConfigCarrier />
		<FullscreenWallpaper config={fullscreenWallpaperConfig} />
		<slot />

		<!-- Music Player - 仅在启用时加载 -->
		{musicPlayerConfig.enable && (
			<MusicPlayer client:visible initialSong={musicInitialSong} />
		)}

		<!-- Pio 看板娘组件 - 仅在启用时加载 -->
		{pioConfig.enable && <Pio client:visible />}

		<!-- Swup 换页滚动锁占位（不参与文档流，避免 300vh 撑高引发 CLS） -->
		<div id="page-height-extend" aria-hidden="true"></div>
	</body>
</html>

<script>
	import { initThemeBootstrap } from "../scripts/theme-bootstrap";
	import { initSwupLifecycle } from "../scripts/swup-lifecycle";
	import { initNavbarScroll } from "../scripts/navbar-scroll";

	initThemeBootstrap();
	initSwupLifecycle();
	initNavbarScroll();
</script>

<!-- 代码块折叠功能 -->
<script>
	import "../scripts/code-collapse.js";
</script>

<!-- 番剧页：Swup 切换后重新初始化卡片与懒加载 -->
<script>
	import "../scripts/anime-page.js";
</script>

<!-- Mermaid 图表：Swup 换页后重新渲染 -->
<script>
	import "../scripts/mermaid-init.js";
</script>

<!-- 主题切换综合性能优化器（包含代码块优化、重型元素优化、性能诊断） -->
<script>
	import "../scripts/theme-optimizer.js";
</script>
